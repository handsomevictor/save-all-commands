# ~/.sac/commands.toml — example data
# Copy this file to ~/.sac/commands.toml to try sac right away.
#
# Search tips:
#   - Type any chars in the TUI to fuzzy-search across cmd, desc, and tags
#   - Type "/" first (vim-style) then your query for the same result
#   - Type "//query" for exact substring search
#   - Tag matches are ranked first — try typing "k8s", "docker", or "git"

# ── Folders ────────────────────────────────────────────────────────────────────

[[folders]]
id = "devops"
parent = ""
name = "DevOps"

[[folders]]
id = "devops.k8s"
parent = "devops"
name = "Kubernetes"

[[folders]]
id = "devops.k8s.debug"
parent = "devops.k8s"
name = "Debug"

[[folders]]
id = "devops.docker"
parent = "devops"
name = "Docker"

[[folders]]
id = "git"
parent = ""
name = "Git"

[[folders]]
id = "git.branch"
parent = "git"
name = "Branch"

# ── Commands ───────────────────────────────────────────────────────────────────

[[commands]]
id = 1
folder = "devops.k8s"
cmd = "kubectl get pods -n {namespace}"
desc = "List all pods in a namespace"
comment = "Make sure the correct kubectl context is active first"
tags = ["k8s", "pods", "list"]
last_used = ""

[[commands]]
id = 2
folder = "devops.k8s"
cmd = "kubectl logs -f {pod} -n {namespace}"
desc = "Stream pod logs in real time"
comment = "Add --tail 100 to limit the initial output"
tags = ["k8s", "logs", "stream"]
last_used = ""

[[commands]]
id = 3
folder = "devops.k8s.debug"
cmd = "kubectl exec -it {pod} -n {namespace} -- /bin/bash"
desc = "Open an interactive shell inside a running pod"
comment = "Use /bin/sh if bash is not available in the image"
tags = ["k8s", "debug", "exec", "shell"]
last_used = ""

[[commands]]
id = 4
folder = "devops.k8s.debug"
cmd = "kubectl describe pod {pod} -n {namespace}"
desc = "Show full pod details including events and resource limits"
comment = "Useful for diagnosing CrashLoopBackOff or ImagePullBackOff"
tags = ["k8s", "debug", "describe", "troubleshoot"]
last_used = ""

[[commands]]
id = 5
folder = "devops.docker"
cmd = "docker ps -a --format 'table {{.Names}}\t{{.Status}}\t{{.Ports}}'"
desc = "Show all containers with status and port mappings"
comment = "Remove -a to show only running containers"
tags = ["docker", "containers", "list"]
last_used = ""

[[commands]]
id = 6
folder = "devops.docker"
cmd = "docker logs -f --tail 100 {container}"
desc = "Stream the last 100 lines of a container log"
comment = "Combine with grep: docker logs {container} 2>&1 | grep ERROR"
tags = ["docker", "logs", "stream"]
last_used = ""

[[commands]]
id = 7
folder = "devops.docker"
cmd = "docker exec -it {container} /bin/sh"
desc = "Open a shell inside a running container"
comment = "Try /bin/bash if /bin/sh is missing"
tags = ["docker", "exec", "shell", "debug"]
last_used = ""

[[commands]]
id = 8
folder = "git"
cmd = "git log --oneline --graph --decorate --all"
desc = "Visualise full branch history as an ASCII graph"
comment = "Alias as 'glog' for quick access"
tags = ["git", "log", "graph", "history"]
last_used = ""

[[commands]]
id = 9
folder = "git.branch"
cmd = "git branch -vv"
desc = "List local branches with upstream tracking status"
comment = "Shows ahead/behind counts vs the remote branch"
tags = ["git", "branch", "upstream"]
last_used = ""
