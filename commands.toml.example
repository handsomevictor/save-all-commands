# ~/.sac/commands.toml — example data
# Copy this file to ~/.sac/commands.toml to try sac right away.
#
# Search tips:
#   - Type any chars in the TUI to fuzzy-search across cmd, desc, and tags
#   - Type "/" first (vim-style) then your query for the same result
#   - Type "//query" for exact substring search
#   - Tag matches are ranked first — try typing "k8s", "docker", "git", or "linux"

# ── Folders ────────────────────────────────────────────────────────────────────

[[folders]]
id = "git"
parent = ""
name = "Git"

[[folders]]
id = "git.commit"
parent = "git"
name = "Commit"

